# Architecture Visualizer Configuration
# Place this file in your project root as .visualizer.yml

# Directories to exclude from analysis
exclude_dirs:
  - venv
  - .venv
  - env
  - node_modules
  - .git
  - __pycache__
  - build
  - dist
  - target
  - bin
  - obj
  - packages
  - .vs
  - .idea
  - .vscode

# Maximum directory depth to scan (default: 10)
max_depth: 10

# Languages to analyze (null = all languages)
# Uncomment and customize to filter by specific languages:
# languages:
#   - python
#   - javascript
#   - typescript
#   - csharp
#   - java

# Performance settings
performance:
  # Enable incremental caching (90% faster re-analysis)
  cache_enabled: true
  
  # Enable performance profiling
  profiling: false

# Output settings
output:
  # Output HTML file name
  html_file: project_architecture.html
  
  # Auto-open browser after analysis
  open_browser: true
