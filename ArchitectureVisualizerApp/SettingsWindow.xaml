<Window x:Class="ArchitectureVisualizerApp.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings - Architecture Visualizer" 
        Height="600" 
        Width="700"
        WindowStartupLocation="CenterOwner"
        Background="#020202"
        ResizeMode="NoResize">
    
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#fff"/>
            <Setter Property="FontFamily" Value="Consolas"/>
        </Style>
        
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#050505"/>
            <Setter Property="Foreground" Value="#0ff"/>
            <Setter Property="BorderBrush" Value="#08f"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#0ff"/>
            <Setter Property="FontFamily" Value="Consolas"/>
        </Style>
        
        <Style TargetType="Button">
            <Setter Property="Background" Value="#020202"/>
            <Setter Property="Foreground" Value="#0ff"/>
            <Setter Property="BorderBrush" Value="#0ff"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect Color="#08f" BlurRadius="8" ShadowDepth="0" Opacity="0.4"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#111"/>
                    <Setter Property="BorderBrush" Value="#08f"/>
                    <Setter Property="Foreground" Value="#fff"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="BorderBrush" Value="#08f"/>
            <Setter Property="Foreground" Value="#08f"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="⚙️ Settings" FontSize="24" FontWeight="Bold" Foreground="#0ff"/>
            <TextBlock Text="Configure analysis behavior and performance" 
                       FontSize="12" 
                       Foreground="#08f" 
                       Margin="0,4,0,0"/>
        </StackPanel>
        
        <!-- Settings Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                
                <!-- Exclude Directories -->
                <Border Background="#050505" 
                        BorderBrush="#08f"
                        BorderThickness="1"
                        CornerRadius="8" 
                        Padding="16" 
                        Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="📁 Exclude Directories" 
                                   FontSize="16" 
                                   FontWeight="SemiBold" 
                                   Foreground="#0ff"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="Directories to skip during analysis (one per line)" 
                                   FontSize="11" 
                                   Foreground="#999" 
                                   Margin="0,0,0,8"/>
                        <TextBox x:Name="excludeDirsTextBox"
                                 Height="120"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"/>
                        <TextBlock Text="Common: venv, node_modules, .git, __pycache__, bin, obj" 
                                   FontSize="10" 
                                   Foreground="#666" 
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- Max Depth -->
                <Border Background="#050505" 
                        BorderBrush="#08f"
                        BorderThickness="1"
                        CornerRadius="8" 
                        Padding="16" 
                        Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="📏 Maximum Scan Depth" 
                                   FontSize="16" 
                                   FontWeight="SemiBold" 
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="Maximum directory nesting depth to scan (1-100)" 
                                   FontSize="11" 
                                   Foreground="#94a3b8" 
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="Note: This is directory levels (e.g., src/core/utils = 3), not file count. Most projects need 10-20." 
                                   FontSize="10" 
                                   Foreground="#64748b" 
                                   FontStyle="Italic"
                                   Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="maxDepthTextBox"
                                     Width="80"
                                     Text="10"/>
                            <TextBlock Text="levels deep" 
                                       VerticalAlignment="Center" 
                                       Margin="8,0,0,0"
                                       Foreground="#94a3b8"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                
                <!-- Language Filter -->
                <Border Background="#050505" 
                        BorderBrush="#08f"
                        BorderThickness="1"
                        CornerRadius="8" 
                        Padding="16" 
                        Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="🔤 Language Filter" 
                                   FontSize="16" 
                                   FontWeight="SemiBold" 
                                   Foreground="#0ff"
                                   Margin="0,0,0,8"/>
                        <CheckBox x:Name="enableLanguageFilterCheckBox"
                                  Content="Enable language filtering"
                                  Margin="0,0,0,8"
                                  Checked="EnableLanguageFilter_Checked"
                                  Unchecked="EnableLanguageFilter_Unchecked"/>
                        <TextBox x:Name="languageFilterTextBox"
                                 Height="60"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 IsEnabled="False"
                                 VerticalScrollBarVisibility="Auto"/>
                        <TextBlock Text="Leave empty to analyze all languages. One per line: python, javascript, csharp, java, etc." 
                                   FontSize="10" 
                                   Foreground="#666" 
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- Performance Settings -->
                <Border Background="#050505" 
                        BorderBrush="#08f"
                        BorderThickness="1"
                        CornerRadius="8" 
                        Padding="16">
                    <StackPanel>
                        <TextBlock Text="⚡ Performance" 
                                   FontSize="16" 
                                   FontWeight="SemiBold" 
                                   Foreground="#0ff"
                                   Margin="0,0,0,12"/>
                        <CheckBox x:Name="cacheEnabledCheckBox"
                                  Content="Enable incremental caching (90% faster re-analysis)"
                                  Margin="0,0,0,8"/>
                        <CheckBox x:Name="profilingEnabledCheckBox"
                                  Content="Enable performance profiling (shows timing breakdown)"/>
                    </StackPanel>
                </Border>
                
            </StackPanel>
        </ScrollViewer>
        
        <!-- Footer Buttons -->
        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <Button Grid.Column="0"
                    Content="📄 Load Config..."
                    Style="{StaticResource SecondaryButton}"
                    Click="LoadConfig_Click"
                    Margin="0,0,8,0"/>
            
            <Button Grid.Column="2"
                    Content="💾 Save"
                    Click="Save_Click"
                    Margin="0,0,8,0"/>
            
            <Button Grid.Column="3"
                    Content="Cancel"
                    Style="{StaticResource SecondaryButton}"
                    Click="Cancel_Click"/>
        </Grid>
    </Grid>
</Window>
