<Window x:Class="ArchitectureVisualizerApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Softcurse · Architecture Visualizer" 
        Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#020202"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize">

    <WindowChrome.WindowChrome>
        <WindowChrome 
            CaptionHeight="40" 
            ResizeBorderThickness="8" 
            GlassFrameThickness="0" 
            CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.Background>
            <SolidColorBrush Color="#020202"/>
        </Grid.Background>

        <!-- Outer Glow Frame -->
        <Border BorderBrush="#0ff" BorderThickness="1" Margin="4">
            <Border.Effect>
                <DropShadowEffect Color="#0ff" BlurRadius="12" ShadowDepth="0" Opacity="0.5"/>
            </Border.Effect>
            
            <Grid Background="#020202">
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>  <!-- Title Bar -->
                    <RowDefinition Height="*"/>   <!-- WebView2 Content -->
                </Grid.RowDefinitions>

                <!-- Title Bar -->
                <Border Grid.Row="0" 
                        BorderBrush="#08f" 
                        BorderThickness="0,0,0,1" 
                        Background="#050505"
                        Padding="15,0">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="SOFTCURSE · ARCHITECTURE VISUALIZER" 
                                       FontFamily="Consolas"
                                       FontSize="13" 
                                       FontWeight="Bold" 
                                       Foreground="#0ff"
                                       VerticalAlignment="Center">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#08f" BlurRadius="10" ShadowDepth="0" Opacity="0.8"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </StackPanel>
                        
                        <!-- Window Controls -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" WindowChrome.IsHitTestVisibleInChrome="True">
                            <Button Content="⚙" Click="Settings_Click" Width="30" Height="25" Margin="0,0,10,0" 
                                    Background="Transparent" BorderThickness="0" Foreground="#08f" FontFamily="Consolas" FontSize="14"
                                    ToolTip="Settings"/>
                            <Button Content="_" Click="Minimize_Click" Width="30" Height="25" Margin="0,0,3,0" 
                                    Background="Transparent" BorderThickness="0" Foreground="#0ff" FontFamily="Consolas" FontSize="14"/>
                            <Button Content="□" Click="Maximize_Click" Width="30" Height="25" Margin="0,0,3,0" 
                                    Background="Transparent" BorderThickness="0" Foreground="#0ff" FontFamily="Consolas" FontSize="14"/>
                            <Button Content="X" Click="Close_Click" Width="30" Height="25" 
                                    Background="Transparent" BorderThickness="0" Foreground="#f00" FontFamily="Consolas" FontSize="14"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- WebView2 — Full GitNexus Visualization -->
                <wv2:WebView2 x:Name="webView" 
                              Grid.Row="1"
                              DefaultBackgroundColor="Transparent"/>
            </Grid>
        </Border>
    </Grid>
</Window>
